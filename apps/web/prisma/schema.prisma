generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  inventory Int
  demand    Int
  leadTime  Int

  createdAt DateTime @default(now())
}

model Insight {
  id         String   @id @default(uuid())
  type       String
  message    String
  impact     Float
  confidence Float

  createdAt  DateTime @default(now())
}